# ============================================
# CelestiOS Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === App Secret ===
SECRET_KEY=                    # Session signing key (generate: openssl rand -base64 64)

# === Database (Supabase) ===
SUPABASE_URL=                  # https://<project-id>.supabase.co
SUPABASE_KEY=                  # Supabase service role key
SUPABASE_DB_URL=               # postgresql://postgres:<password>@db.<project-id>.supabase.co:5432/postgres

# === Google OAuth 2.0 ===
GOOGLE_CLIENT_ID=              # Google Cloud Console -> Credentials -> OAuth client ID
GOOGLE_CLIENT_SECRET=          # Google Cloud Console -> Credentials -> OAuth client secret

# === Microsoft OAuth 2.0 ===
MICROSOFT_CLIENT_ID=           # Azure AD -> App registrations -> Application (client) ID
MICROSOFT_CLIENT_SECRET=       # Azure AD -> App registrations -> Client secret value

# === OpenAI ===
OPENAI_API_KEY=                # https://platform.openai.com/api-keys

# === Health Integrations ===
OURA_CLIENT_ID=                # https://cloud.ouraring.com/v2/docs
OURA_CLIENT_SECRET=
FITBIT_CLIENT_ID=              # https://dev.fitbit.com/apps
FITBIT_CLIENT_SECRET=

# === Email (SendGrid) ===
SENDGRID_API_KEY=              # https://app.sendgrid.com/settings/api_keys
SENDGRID_FROM_EMAIL=           # Verified sender email
SENDGRID_FROM_NAME=CelestiOS

# === Frontend ===
FRONTEND_URL=                  # e.g., https://celesti.life

# === Logging ===
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
